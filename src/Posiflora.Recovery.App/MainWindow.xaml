<ui:FluentWindow x:Class="Posiflora.Recovery.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="POS Radar"
                 Height="760"
                 Width="1220"
                 MinHeight="680"
                 MinWidth="1050"
                 WindowStartupLocation="CenterScreen"
                 Background="#F3F5F8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="POS Radar" ShowMaximize="True" ShowMinimize="True" ShowClose="True" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#101828" Padding="18,0">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="POS Radar" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                        <Border Margin="14,0,0,0" Padding="9,4" CornerRadius="10" Background="#1D2939">
                            <TextBlock Text="Режим: UEMA / ошибка 11" Foreground="#D0D5DD" FontSize="12" />
                        </Border>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Запустить диагностику"
                                Command="{Binding RunDiagnosticsCommand}"
                                Padding="14,8"
                                Margin="0,0,8,0"
                                Background="#12B76A"
                                Foreground="White"
                                BorderThickness="0" />
                        <Button Content="Открыть логи"
                                Click="OpenLogsButton_Click"
                                Padding="12,8"
                                Margin="0,0,8,0" />
                        <Button Content="Экспорт отчета"
                                Click="ExportReportButton_Click"
                                Padding="12,8"
                                Margin="0,0,8,0" />
                        <Button Content="Свернуть в трей"
                                Click="MinimizeToTrayButton_Click"
                                Padding="12,8" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Профили" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusText}" Margin="0,8,0,0" Foreground="#667085" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding AgentStatusText}" Margin="0,12,0,16" Foreground="#475467" TextWrapping="Wrap" />
                        </StackPanel>

                        <ListBox ItemsSource="{Binding Profiles}"
                                 SelectedItem="{Binding SelectedProfile}"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Margin="0,4" CornerRadius="8" Background="#EEF4FF">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#101828" />
                                            <TextBlock Text="{Binding Description}" Foreground="#667085" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Grid Grid.Column="1" Margin="16,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="96" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#FEF3F2" CornerRadius="10" Padding="16" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="{Binding CriticalCount}" FontSize="26" FontWeight="SemiBold" Foreground="#B42318" />
                                <TextBlock Text="Критические" Foreground="#7A271A" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FFFAEB" CornerRadius="10" Padding="16" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="{Binding WarningCount}" FontSize="26" FontWeight="SemiBold" Foreground="#B54708" />
                                <TextBlock Text="Предупреждения" Foreground="#7A2E0E" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#F2F4F7" CornerRadius="10" Padding="16" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalCount}" FontSize="26" FontWeight="SemiBold" Foreground="#344054" />
                                <TextBlock Text="Всего проблем" Foreground="#475467" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="#ECFDF3" CornerRadius="10" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Только чтение" FontSize="22" FontWeight="SemiBold" Foreground="#027A48" />
                                <TextBlock Text="Ремонтные действия пока не выполняются" Foreground="#05603A" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="#E4E7EC"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16"
                                Margin="0,0,10,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="Диагностика" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SummaryText}" Foreground="#667085" />
                                </StackPanel>

                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding Findings}"
                                         SelectedItem="{Binding SelectedFinding}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12" Margin="0,0,0,10" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Height="30"
                                                            CornerRadius="15"
                                                            Background="{Binding SeverityBackground}"
                                                            HorizontalAlignment="Left"
                                                            Padding="12,0">
                                                        <TextBlock Text="{Binding SeverityTitle}"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Source}" Foreground="#667085" Margin="0,3,0,0" />
                                                        <TextBlock Text="{Binding Evidence}"
                                                                   Foreground="#475467"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,8,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1" Margin="10,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1.2*" />
                                <RowDefinition Height="0.8*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="White"
                                    BorderBrush="#E4E7EC"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16"
                                    Margin="0,0,0,10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel DataContext="{Binding SelectedFinding}">
                                        <TextBlock Text="Сведения" FontSize="20" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Title}" Margin="0,14,0,0" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />

                                        <TextBlock Text="Данные проверки" Margin="0,18,0,6" FontWeight="SemiBold" Foreground="#344054" />
                                        <TextBlock Text="{Binding Evidence}" TextWrapping="Wrap" Foreground="#475467" />

                                        <TextBlock Text="Пояснение" Margin="0,18,0,6" FontWeight="SemiBold" Foreground="#344054" />
                                        <TextBlock Text="{Binding Explanation}" TextWrapping="Wrap" Foreground="#475467" />

                                        <TextBlock Text="Рекомендация" Margin="0,18,0,6" FontWeight="SemiBold" Foreground="#344054" />
                                        <TextBlock Text="{Binding RecommendedAction}" TextWrapping="Wrap" Foreground="#475467" />

                                        <CheckBox Content="Доступно автоисправление"
                                                  IsChecked="{Binding CanAutoFix, Mode=OneWay}"
                                                  IsEnabled="False"
                                                  Margin="0,18,0,0" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <Border Grid.Row="1"
                                    Background="White"
                                    BorderBrush="#E4E7EC"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Журнал" FontSize="18" FontWeight="SemiBold" />
                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding LogLines}"
                                             Margin="0,10,0,0"
                                             BorderThickness="0"
                                             Background="#F9FAFB"
                                             FontFamily="Consolas"
                                             FontSize="12" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
