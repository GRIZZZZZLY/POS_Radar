<ui:FluentWindow x:Class="Posiflora.Recovery.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="POS Radar"
                 Height="720"
                 Width="1180"
                 MinHeight="620"
                 MinWidth="980"
                 WindowStartupLocation="CenterScreen"
                 Background="#F4F6F8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="44" />
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="POS Radar" ShowMaximize="True" ShowMinimize="True" ShowClose="True" />

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#DFE4EA" BorderThickness="0,0,0,1" Padding="14,0">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="POS Radar" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1F2937" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Запустить диагностику" Command="{Binding RunDiagnosticsCommand}" Height="30" Padding="12,0" Margin="0,0,8,0" Background="#0F9F6E" Foreground="White" BorderBrush="#0F9F6E" />
                    <Button Content="Открыть логи" Click="OpenLogsButton_Click" Height="30" Padding="12,0" Margin="0,0,8,0" />
                    <Button Content="Экспорт отчета" Click="ExportReportButton_Click" Height="30" Padding="12,0" Margin="0,0,8,0" />
                    <Button Content="Свернуть в трей" Click="MinimizeToTrayButton_Click" Height="30" Padding="12,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Background="#FBFCFD" BorderBrush="#DFE4EA" BorderThickness="0,0,0,1" Padding="12,6">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Border Height="28" Padding="12,0" Margin="0,0,6,0" CornerRadius="6" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="UEMA / ошибка 11" FontWeight="SemiBold" Foreground="#1D4ED8" />
                            <Border MinWidth="18" Height="18" Margin="8,0,0,0" Padding="6,0" CornerRadius="9" Background="#B42318">
                                <TextBlock Text="{Binding CriticalCount}" Foreground="White" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Height="28" Padding="12,0" Margin="0,0,6,0" CornerRadius="6">
                        <TextBlock Text="Службы Windows" VerticalAlignment="Center" Foreground="#64748B" />
                    </Border>
                    <Border Height="28" Padding="12,0" Margin="0,0,6,0" CornerRadius="6">
                        <TextBlock Text="Wi-Fi сеть" VerticalAlignment="Center" Foreground="#64748B" />
                    </Border>
                    <Border Height="28" Padding="12,0" Margin="0,0,6,0" CornerRadius="6">
                        <TextBlock Text="Локальная сеть" VerticalAlignment="Center" Foreground="#64748B" />
                    </Border>
                    <Border Height="28" Padding="12,0" CornerRadius="6">
                        <TextBlock Text="Устройства" VerticalAlignment="Center" Foreground="#64748B" />
                    </Border>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#64748B" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="3" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.92*" />
                <ColumnDefinition Width="1.08*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="210" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Background="White" BorderBrush="#DFE4EA" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#DFE4EA" BorderThickness="0,0,0,1" Padding="12,0">
                        <DockPanel>
                            <TextBlock Text="Диагностика" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SummaryText}" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#64748B" />
                        </DockPanel>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Findings}" SelectedItem="{Binding SelectedFinding}" BorderThickness="0" Padding="10" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,0,0,8" BorderBrush="#DFE4EA" BorderThickness="1" CornerRadius="7" Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="86" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Height="26" Padding="9,0" CornerRadius="13" Background="{Binding SeverityBackground}" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SeverityTitle}" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Evidence}" FontFamily="Consolas" FontSize="12" Foreground="#475569" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" Grid.Row="0" Background="White" BorderBrush="#DFE4EA" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#DFE4EA" BorderThickness="0,0,0,1" Padding="12,0">
                        <DockPanel>
                            <TextBlock Text="Сведения" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedFinding.Source}" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#64748B" />
                        </DockPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="12" DataContext="{Binding SelectedFinding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Заголовок" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,12,8" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Title}" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Данные проверки" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,12,8" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Evidence}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Пояснение" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,12,8" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Explanation}" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Автоисправление" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,12,8" />
                            <CheckBox Grid.Row="3" Grid.Column="1" Content="Доступно" IsChecked="{Binding CanAutoFix, Mode=OneWay}" IsEnabled="False" Margin="0,0,0,8" />
                            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Padding="10" CornerRadius="7" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" Margin="0,4,0,0">
                                <TextBlock Text="{Binding RecommendedAction}" TextWrapping="Wrap" Foreground="#7C2D12" />
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Grid.Row="1" Background="#0B1020" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#1F2937" BorderThickness="0,0,0,1" Padding="12,0" Background="White" CornerRadius="8,8,0,0">
                        <DockPanel>
                            <TextBlock Text="Логи" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1F2937" />
                            <TextBlock Text="подробный ход проверки" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#64748B" />
                        </DockPanel>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" BorderThickness="0" Background="#0B1020" Padding="10" FontFamily="Consolas" FontSize="12">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="84" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Time}" Foreground="#D1D5DB" />
                                    <TextBlock Grid.Column="1" Text="{Binding LevelTitle}" Foreground="{Binding LevelBrush}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="{Binding Source}" Foreground="#CBD5E1" />
                                    <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#D1D5DB" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" Background="White" BorderBrush="#DFE4EA" BorderThickness="0,1,0,0" Padding="12,0">
            <DockPanel>
                <TextBlock Text="Готово · режим только чтение · логи: %LocalAppData%\POS Radar\logs\pos-radar.log" VerticalAlignment="Center" Foreground="#64748B" FontSize="12" />
                <TextBlock Text="{Binding AgentStatusText}" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#64748B" FontSize="12" />
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
